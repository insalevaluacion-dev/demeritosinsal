{
  "name": "demeritos-insal",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/start-dev.mjs",
    "dev:local": "node scripts/start-dev.mjs --local",
    "dev:railway": "node scripts/start-dev.mjs --railway",
    "dev:fast": "next dev --turbopack",
    "dev:mobile": "next dev --turbopack -H 0.0.0.0",
    "build": "next build && node scripts/copy-standalone-assets.mjs",
    "start": "node scripts/start-production.mjs",
    "lint": "next lint",
    "seed": "node scripts/seed.js",
    "db:seed-demo": "node scripts/seed-demo-reportes.mjs",
    "db:setup-railway": "node scripts/setup-railway-public.mjs",
    "db:export-railway": "node scripts/export-railway-snapshot.mjs",
    "db:setup-local": "node scripts/setup-local-db.mjs",
    "db:update-catalogs": "node scripts/update-catalogs.mjs",
    "db:migrate-fks": "node scripts/migrate-public-fks.mjs",
    "db:fix-sequences": "node scripts/fix-sequences.mjs",
    "verify:local": "node scripts/verify-local.mjs",
    "verify:railway": "node scripts/verify-railway.mjs",
    "cap:icons": "node scripts/generate-android-icons.mjs",
    "cap:prepare": "node scripts/capacitor-prepare.mjs",
    "cap:sync": "node scripts/generate-android-icons.mjs && node scripts/capacitor-prepare.mjs && npx cap sync android",
    "cap:android": "npx cap open android",
    "cap:run:android": "npx cap run android",
    "deploy:capacitor-url": "node scripts/railway-deploy-setup.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "^16.2.5",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "embedded-postgres": "^18.4.0-beta.17",
    "@capacitor/cli": "^7.4.2"
  }
}
